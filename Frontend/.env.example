# ArthSaathi Frontend — Environment Variables
# Copy to .env or .env.development and fill in values.
# On Windows, if API calls fail, try VITE_API_URL=http://127.0.0.1:8000

VITE_API_URL=http://localhost:8000

# Supabase (for auth — get from supabase.com/dashboard > Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
